# WebSocket endpoint for MCP bridge
MCP_ENDPOINT=wss://your-mcp-endpoint

# Runtime mode
# Set MCP_MODE=local (or MCP_LOCAL_MODE=1) to force local generation + embeddings via Ollama.
MCP_MODE=cloud
MCP_LOCAL_MODE=0

# Local Ollama settings (used when local mode is enabled)
# Recommended for 16GB RAM: llama3.1:8b + nomic-embed-text
MCP_LOCAL_BASE_URL=http://127.0.0.1:11434
MCP_LOCAL_LLM_MODEL=llama3.1:8b
MCP_LOCAL_EMBEDDING_MODEL=nomic-embed-text
MCP_PROVIDER_TIMEOUT_SECONDS=180

# Provider keys (fallback priority: OpenAI -> Claude -> Gemini -> TogetherAI)
MCP_OPENAI_API_KEY=replace_with_openai_key
MCP_CLAUDE_API_KEY=replace_with_claude_key
MCP_ANTHROPIC_API_KEY=
MCP_GEMINI_API_KEY=replace_with_gemini_key
MCP_TOGETHER_API_KEY=replace_with_together_key

# Optional alias keys also supported by code (use only if needed)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# TOGETHER_API_KEY=

# Standalone legal answer models
MCP_LLM_MODEL=gpt-4o-mini
MCP_EMBEDDING_MODEL=text-embedding-3-small
MCP_EMBEDDING_DIMENSIONS=

# Optional provider-specific model overrides
MCP_OPENAI_LLM_MODEL=
MCP_OPENAI_EMBEDDING_MODEL=
MCP_CLAUDE_LLM_MODEL=claude-3-5-sonnet-latest
MCP_CLAUDE_MAX_TOKENS=1200
MCP_GEMINI_LLM_MODEL=gemini-2.0-flash
MCP_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
MCP_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
MCP_TOGETHER_LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
MCP_TOGETHER_EMBEDDING_MODEL=togethercomputer/m2-bert-80M-32k-retrieval
MCP_TOGETHER_BASE_URL=https://api.together.xyz/v1

# Zilliz / Milvus online connection (preferred for cloud)
MCP_MILVUS_ENDPOINT=https://your-zilliz-endpoint
MCP_MILVUS_TOKEN=replace_with_zilliz_token
MCP_MILVUS_DATABASE=default
MCP_MILVUS_VECTOR_FIELD=dense_vector

# Local/self-hosted Milvus fallback (used when MCP_MILVUS_ENDPOINT is empty)
MCP_MILVUS_URI=http://localhost:19530
MCP_MILVUS_COLLECTION=legal_articles

# Neo4j connection for graph expansion
MCP_NEO4J_URI=neo4j+s://your-neo4j-instance.databases.neo4j.io
MCP_NEO4J_USER=neo4j
MCP_NEO4J_PASSWORD=change_me
MCP_NEO4J_DATABASE=Dogzilla

# Runtime tuning
MCP_TOP_K=4
MCP_MAX_TOP_K=8
MCP_CACHE_TTL_SECONDS=300
MCP_CONTEXT_CHAR_BUDGET=2800
MCP_MAX_CONTEXT_ITEMS=8
MCP_MAX_ITEM_CHARS=700

# Provider routing controls (optional)
# Values: openai | claude | gemini | togetherai
MCP_PREFERRED_GENERATION_PROVIDER=
MCP_PREFERRED_EMBEDDING_PROVIDER=
MCP_STRICT_PREFERRED_PROVIDER=0

# Startup preflight: verify model API connectivity before server starts
MCP_VERIFY_PROVIDER_ON_STARTUP=1
MCP_VERIFY_PROVIDER_EMBEDDINGS=1

# Robot control server
ROBOT_IP=192.168.1.100
